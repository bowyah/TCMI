# ─────────────────────────────────────────────
#  TCMI Environment Configuration
#  Copy this file to .env and fill in values.
#  NEVER commit .env to Git.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
# LOCAL:
# APP_ENV=local
# APP_URL=http://localhost/TCMI

# PRODUCTION (tcminitiative.org — deployed to domain root):
APP_ENV=production
APP_URL=https://tcminitiative.org

# ── Database ─────────────────────────────────
DB_HOST=localhost
DB_NAME=tcmi_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ── JWT ──────────────────────────────────────
# Generate a secure random secret: openssl rand -hex 32
JWT_SECRET=tcmi_super_secret_change_this_in_production_2026
JWT_EXPIRES_DAYS=7

# ── File Uploads ─────────────────────────────
UPLOAD_URL=/api/uploads/
MAX_FILE_MB=10

# ── Seed Admin ───────────────────────────────
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=change_me_in_production
SEED_ADMIN_NAME=Administrator

# ── CORS ─────────────────────────────────────
# Use * for local dev, restrict to your domain in production
CORS_ORIGIN=https://tcminitiative.org
